// Prisma schema for Better Auth + PostgreSQL
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Better Auth required tables
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  // Custom fields for your app
  role          String    @default("user")
  isActive      Boolean   @default(true)
  // Relations
  rooms         Room[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Your app specific models
model Room {
  id          String   @id @default(cuid())
  name        String
  width       Int
  height      Int
  backgroundImageUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String
  user        User     @relation(fields: [createdBy], references: [id])
  wallAreas   WallArea[]
}

model WallArea {
  id          String   @id @default(cuid())
  roomId      String
  guid        String
  tileType    String[]
  baseWidth   Float
  baseHeight  Float
  bottomLeft  Json     // [x, y] coordinates
  topLeft     Json     // [x, y] coordinates
  topRight    Json     // [x, y] coordinates
  bottomRight Json     // [x, y] coordinates
  tileRateWidth  Float
  tileRateHeight Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}
